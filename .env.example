# Docker Compose mode: "dev" or "prod"
COMPOSE_PROFILES=dev

# Database
POSTGRES_USER=tcgplayer
POSTGRES_PASSWORD=tcgplayer
POSTGRES_DB=tcgplayer

# For Docker: use 'db' (prod) or 'db-dev' (dev) as hostname (Docker DNS)
# For local development: use 'localhost'
DATABASE_URL=postgresql://tcgplayer:tcgplayer@db-dev:5432/tcgplayer

# TCGTracking API (no auth needed)
TCGTRACKING_BASE_URL=https://tcgtracking.com/tcgapi/v1

# Riftbound category ID on TCGPlayer/TCGTracking
RIFTBOUND_CATEGORY_ID=89

# Pricing
MIN_LISTING_PRICE_CENTS=5
LISTING_PRICE_MULTIPLIER=0.98
MAX_PRICE_DROP_PERCENT=20

# Price checking
PRICE_CHECK_INTERVAL_HOURS=12

# Redis
# For Docker: use 'redis' (prod) or 'redis-dev' (dev) as hostname (Docker DNS)
# For local development: use 'localhost'
REDIS_URL=redis://localhost:6379

# Telegram (Phase 3)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_NOTIFY_SALE_CONFIRMED=true
TELEGRAM_NOTIFY_ORDER_SHIPPED=true

# Seller info for invoice / packing slip templates (Phase 3.3)
SELLER_NAME=
SELLER_ID=

# Server
PORT=3000
HOST=0.0.0.0
NODE_ENV=development
